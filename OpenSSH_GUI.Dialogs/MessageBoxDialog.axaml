<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OpenSSH_GUI.Dialogs.MessageBoxDialog"
        Title="Message"
        Width="440"
        MinWidth="300"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaToDecorationsHint="False">

    <Border Padding="24 20 24 16">
        <Grid RowDefinitions="*,16,Auto">

            <!-- Content row: icon + message -->
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Spacing="16"
                        VerticalAlignment="Top">

                <!-- Icon label – visibility and content set from code-behind -->
                <TextBlock x:Name="PART_Icon"
                           FontSize="28"
                           VerticalAlignment="Top"
                           IsVisible="False" />

                <TextBlock x:Name="PART_Message"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           MaxWidth="340"
                           FontSize="14" />
            </StackPanel>

            <!-- Spacer -->
            <Border Grid.Row="1" />

            <!-- Button row -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">

                <Button x:Name="PART_YesButton"
                        Content="Yes"
                        MinWidth="88"
                        IsVisible="False"
                        Click="OnYesClick" />

                <Button x:Name="PART_NoButton"
                        Content="No"
                        MinWidth="88"
                        IsVisible="False"
                        Click="OnNoClick" />

                <Button x:Name="PART_OkButton"
                        Content="OK"
                        MinWidth="88"
                        IsDefault="True"
                        IsVisible="False"
                        Click="OnOkClick" />

                <Button x:Name="PART_CancelButton"
                        Content="Cancel"
                        MinWidth="88"
                        IsCancel="True"
                        IsVisible="False"
                        Click="OnCancelClick" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
