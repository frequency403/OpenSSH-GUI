<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:viewModels="clr-namespace:OpenSSH_GUI.ViewModels"
        xmlns:openSshGui="clr-namespace:OpenSSH_GUI.Resources"
        xmlns:converters="clr-namespace:OpenSSH_GUI.Converters"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:keys="clr-namespace:OpenSSH_GUI.Core.Lib.Keys;assembly=OpenSSH_GUI.Core"
        xmlns:controls="clr-namespace:OpenSSH_GUI.Resources.Controls"
        mc:Ignorable="d" d:DesignWidth="1150" d:DesignHeight="450"
        x:Class="OpenSSH_GUI.Views.MainWindow"
        x:DataType="viewModels:MainWindowViewModel"
        Width="1150"
        Height="450"
        Title="{Binding WindowTitle}">
    <Window.Styles>
        <Style Selector="DataGrid">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="RowBackground" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource ForegroundPrimaryBrush}" />
            <Setter Property="FontSize" Value="{DynamicResource SystemFontSize}" />
            <Setter Property="Padding" Value="8 6" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="SeparatorBrush" Value="{DynamicResource BorderBrush}" />
        </Style>
        <Style Selector="DataGridColumnHeader:pointerover /template/ Grid#PART_ColumnHeaderRoot">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="MinHeight" Value="60" />
            <Setter Property="ToolTip.ShowDelay" Value="0" />
            <Setter Property="ToolTip.ShowOnDisabled" Value="True" />
            <Setter Property="ToolTip.Tip">
                <Template>
                    <StackPanel x:DataType="keys:SshKeyFile">
                        <StackPanel IsVisible="{Binding !Password.IsValid}">
                            <Label IsVisible="{Binding !NeedsPassword}"
                                   Content="{x:Static openSshGui:StringsAndTexts.MainWindowKeyNotPasswordProtected}" />
                            <Label IsVisible="{Binding NeedsPassword}"
                                   Content="{x:Static openSshGui:StringsAndTexts.MainWindowKeyPasswordProtectedLocked}" />
                        </StackPanel>
                        <Label IsVisible="{Binding Password.IsValid}"
                               Content="{x:Static openSshGui:StringsAndTexts.MainWindowKeyPasswordProtectedUnlocked}" />
                    </StackPanel>
                </Template>
            </Setter>
        </Style>
        <Style Selector="DataGridRow:pointerover /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Opacity" Value="0.4" />
        </Style>
        <Style Selector="DataGridCell">
            <Setter Property="Padding" Value="8 6" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="* 7* *" ColumnDefinitions="* * *" Margin="20 5" HorizontalAlignment="Stretch">

        <!-- Key List -->

        <DataGrid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Grid.RowSpan="2"
                  IsReadOnly="True"
                  CanUserReorderColumns="False"
                  CanUserResizeColumns="True"
                  AutoGenerateColumns="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  ItemsSource="{Binding SshKeyManager.SshKeys}">
            <DataGrid.Columns>

                <!-- Key Type column -->
                <DataGridTemplateColumn Width="1*"
                                        CanUserSort="True"
                                        CanUserResize="False"
                                        CanUserReorder="False"
                                        SortMemberPath="KeyType"
                                        CellTemplate="{StaticResource SshKeyTypeStyle}">
                    <DataGridTemplateColumn.Header>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="3" Margin="5">
                            <materialIcons:MaterialIcon Kind="KeyVariant" />
                            <Label
                                Content="{x:Static openSshGui:StringsAndTexts.MainWindowDataGridColumnHeadingKeyTypeText}" />
                        </StackPanel>
                    </DataGridTemplateColumn.Header>

                </DataGridTemplateColumn>

                <!-- Fingerprint column-->
                <DataGridTemplateColumn Width="3*"
                                        CanUserSort="True"
                                        CanUserResize="True"
                                        CanUserReorder="False"
                                        SortMemberPath="Fingerprint"
                                        CellTemplate="{StaticResource SshKeyFingerprintStyle}">
                    <DataGridTemplateColumn.Header>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="3" Margin="5">
                            <materialIcons:MaterialIcon Kind="Fingerprint" />
                            <Label
                                Content="{x:Static openSshGui:StringsAndTexts.MainWindowDataGridColumnHeadingFingerprintText}" />
                        </StackPanel>
                    </DataGridTemplateColumn.Header>
                </DataGridTemplateColumn>

                <!-- Comment column -->
                <DataGridTemplateColumn Width="1*"
                                        CanUserSort="True"
                                        CanUserResize="True"
                                        CanUserReorder="False"
                                        SortMemberPath="Comment">
                    <DataGridTemplateColumn.Header>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="3" Margin="5">
                            <materialIcons:MaterialIcon Kind="Comment" />
                            <Label
                                Content="{x:Static openSshGui:StringsAndTexts.MainWindowDataGridColumnHeadingCommentText}" />
                        </StackPanel>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="keys:SshKeyFile">
                            <TextBlock Padding="5" Text="{Binding Comment}" Margin="5"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       IsEnabled="{Binding !NeedsPassword}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Export / Actions column -->
                <DataGridTemplateColumn Width="1*" CanUserSort="False" CanUserResize="False"
                                        CanUserReorder="False" CellTemplate="{StaticResource SshKeyExportButtons}">
                    <DataGridTemplateColumn.Header>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="3" Margin="5">
                            <materialIcons:MaterialIcon Kind="FileExportOutline" />
                            <Label
                                Content="{x:Static openSshGui:StringsAndTexts.MainWindowDataGridColumnHeadingExportDeleteText}" />
                        </StackPanel>
                    </DataGridTemplateColumn.Header>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>


        <!-- Bottom Controls -->

        <UniformGrid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Rows="1" Columns="0">

            <!-- Open Add Key Window -->

            <Button Command="{Binding OpenCreateKeyWindowCommand}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Background="{DynamicResource VerifiedBrush}">
                <ToolTip.Tip>
                    <Label Content="{x:Static openSshGui:StringsAndTexts.MainWindowAddKeyToolTip}" />
                </ToolTip.Tip>
                <StackPanel Orientation="Horizontal">
                    <materialIcons:MaterialIcon Kind="KeyAdd" />
                </StackPanel>
            </Button>

            <!-- Open Edit Known Host Window  -->

            <Button Command="{Binding OpenEditKnownHostsWindowCommand}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Background="{DynamicResource InfoColor}">
                <ToolTip.Tip>
                    <StackPanel>
                        <TextBlock Margin="2"
                                   Text="{x:Static openSshGui:StringsAndTexts.MainWindowEditKnownHostsFileToolTip}" />
                        <Label Content="{x:Static openSshGui:StringsAndTexts.MainWindowIsNotRemoteTooltipText}"
                               Foreground="{DynamicResource RevokedBrush}"
                               IsVisible="{Binding !ServerConnectionService.IsConnected}" />
                    </StackPanel>
                </ToolTip.Tip>
                <StackPanel Orientation="Horizontal">
                    <materialIcons:MaterialIcon Kind="FileAccountOutline" />
                </StackPanel>
            </Button>

            <!-- Open Edit Authorized Keys Window -->

            <Button HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Background="{DynamicResource ModifiedBrush}"
                    Command="{Binding OpenEditAuthorizedKeysWindowCommand}">
                <ToolTip.Tip>
                    <StackPanel>
                        <Label Content="{x:Static openSshGui:StringsAndTexts.MainWindowEditAuthorizedKeys}" />
                        <Label Content="{x:Static openSshGui:StringsAndTexts.MainWindowIsNotRemoteTooltipText}"
                               Foreground="{DynamicResource DangerBrush}"
                               IsVisible="{Binding !ServerConnectionService.IsConnected}" />
                    </StackPanel>
                </ToolTip.Tip>
                <StackPanel Orientation="Horizontal">
                    <materialIcons:MaterialIcon Kind="FileCogOutline" />
                </StackPanel>
            </Button>
        </UniformGrid>

        <!-- Status Panel -->
        <Border Grid.Row="2" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="10 5"
                Background="{DynamicResource DisconnectedBrush}" CornerRadius="5">
            <UniformGrid Columns="0" Rows="1" ColumnSpacing="10">

                <!-- Connection -->

                <controls:FlyoutButton HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="10 5"
                                       Padding="7" Classes="Clickable"
                                       CornerRadius="5">
                    <ToolTip.Tip>
                        <StackPanel>
                            <Grid ColumnDefinitions="* 2*" RowDefinitions="* * *"
                                  IsVisible="{Binding ServerConnectionService.IsConnected, FallbackValue=False}">
                                <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Center"
                                       Content="{Binding ServerConnectionService.ServerConnection.ConnectionString}"
                                       FontWeight="Bold" />
                                <Label Grid.Row="1" Grid.Column="0"
                                       Content="{x:Static openSshGui:StringsAndTexts.MainWindowConnectionTooltipServerOs}" />
                                <Label Grid.Row="1" Grid.Column="1"
                                       Content="{Binding ServerConnectionService.ServerConnection.ServerOs, Converter={x:Static converters:Converter.PlatformIdToStringConverter}}"
                                       FontWeight="Bold" />
                                <Label Grid.Row="2" Grid.Column="0"
                                       Content="{x:Static openSshGui:StringsAndTexts.MainWindowConnectionTooltipConnectedOn}" />
                                <Label Grid.Row="2" Grid.Column="1"
                                       Content="{Binding ServerConnectionService.ServerConnection.ConnectionTime}" />
                            </Grid>
                            <Label
                                Content="{x:Static openSshGui:StringsAndTexts.MainWindowConnectionTooltipDisconnected}"
                                IsVisible="{Binding !ServerConnectionService.IsConnected}" />
                        </StackPanel>


                    </ToolTip.Tip>
                    <controls:FlyoutButton.Flyout>
                        <MenuFlyout PlacementAnchor="Top" Placement="Top">
                            <MenuItem Header="{x:Static openSshGui:StringsAndTexts.MainWindowConnectMenuConnect}"
                                      IsEnabled="{Binding !ServerConnectionService.IsConnected}"
                                      Command="{Binding OpenConnectToServerWindowCommand}">
                                <MenuItem.Icon>
                                    <materialIcons:MaterialIconExt Kind="LanConnect" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{x:Static openSshGui:StringsAndTexts.MainWindowConnectMenuDisconnect}"
                                      IsEnabled="{Binding ServerConnectionService.IsConnected}"
                                      Command="{Binding DisconnectFromServerCommand}">
                                <MenuItem.Icon>
                                    <materialIcons:MaterialIconExt Kind="LanDisconnect" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </MenuFlyout>
                    </controls:FlyoutButton.Flyout>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    IsVisible="{Binding ServerConnectionService.IsConnected}">
                            <materialIcons:MaterialIcon Kind="Signal" Foreground="{DynamicResource ConnectedBrush}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    IsVisible="{Binding !ServerConnectionService.IsConnected}">
                            <materialIcons:MaterialIcon Kind="SignalOff" Foreground="{DynamicResource RevokedBrush}" />
                        </StackPanel>
                    </StackPanel>
                </controls:FlyoutButton>


                <!-- Item Count -->

                <controls:FlyoutButton Margin="10 5"
                                       Padding="5" HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch" CornerRadius="5">
                    <controls:FlyoutButton.Styles>
                        <Style Selector="materialIcons|MaterialIcon.spin">
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <RotateTransform Angle="0" />
                                </Setter.Value>
                            </Setter>
                            <Style.Animations>
                                <Animation Duration="0:0:1.2" IterationCount="INFINITE">
                                    <KeyFrame Cue="0%">
                                        <Setter Property="RotateTransform.Angle" Value="0" />
                                    </KeyFrame>
                                    <KeyFrame Cue="100%">
                                        <Setter Property="RotateTransform.Angle" Value="360" />
                                    </KeyFrame>
                                </Animation>
                            </Style.Animations>
                        </Style>
                    </controls:FlyoutButton.Styles>
                    <Panel>
                        <Panel IsVisible="{Binding !SshKeyManager.Processing}">
                            <materialIcons:MaterialIcon Kind="{Binding ItemsCountIcon}" />
                            <ToolTip.Tip>
                                <Label Content="{Binding ItemsCountTooltip}" />
                            </ToolTip.Tip>
                        </Panel>
                        <Panel IsVisible="{Binding SshKeyManager.Processing}">
                            <materialIcons:MaterialIcon Classes="spin"
                                                        Kind="Reload"
                                                        RenderTransformOrigin="50%,50%">
                                <ToolTip.Tip>
                                    <TextBlock Text="{x:Static openSshGui:StringsAndTexts.MainWindowReloadingKeys}" />
                                </ToolTip.Tip>
                            </materialIcons:MaterialIcon>
                        </Panel>
                    </Panel>
                </controls:FlyoutButton>


                <!-- Settings -->

                <controls:FlyoutButton Margin="10 5" Classes="Clickable"
                                       Padding="7" HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch" CornerRadius="5">
                    <ToolTip.Tip>
                        <Label Content="{x:Static openSshGui:StringsAndTexts.MainWindowRightClickOptions}" />
                    </ToolTip.Tip>
                    <controls:FlyoutButton.Flyout>
                        <MenuFlyout PlacementAnchor="Top" Placement="Top">
                            <MenuItem
                                Header="{x:Static openSshGui:StringsAndTexts.MainWindowSettingsMenuReloadKeysFromDisk}"
                                Command="{Binding ReloadKeysCommand}">
                                <MenuItem.Icon>
                                    <materialIcons:MaterialIcon Kind="Reload" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="{x:Static openSshGui:StringsAndTexts.MainWindowSettingsMenuAppSettings}"
                                      Command="{Binding OpenApplicationSettingsWindowCommand}">
                                <MenuItem.Icon>
                                    <materialIcons:MaterialIcon Kind="ApplicationSettingsOutline" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem
                                Header="{x:Static openSshGui:StringsAndTexts.MainWindowSettingsMenuLocalUserSshConfig}"
                                Command="{Binding ShowNotImplementedMessageBoxCommand}">
                                <MenuItem.Icon>
                                    <materialIcons:MaterialIcon Kind="AccountCogOutline" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem
                                Header="{x:Static openSshGui:StringsAndTexts.MainWindowSettingsMenuMachineSshdConfig}"
                                Command="{Binding ShowNotImplementedMessageBoxCommand}">
                                <MenuItem.Icon>
                                    <materialIcons:MaterialIcon Kind="BookCogOutline" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator />
                            <MenuItem
                                Header="{x:Static openSshGui:StringsAndTexts.MainWindowSettingsMenuRemoteUserSshConfig}"
                                IsEnabled="{Binding ServerConnectionService.IsConnected}"
                                Command="{Binding ShowNotImplementedMessageBoxCommand}">
                                <MenuItem.Icon>
                                    <materialIcons:MaterialIcon Kind="ServerNetworkOutline" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem
                                Header="{x:Static openSshGui:StringsAndTexts.MainWindowSettingsMenuRemoteMachineSshdConfig}"
                                IsEnabled="{Binding ServerConnectionService.IsConnected}"
                                Command="{Binding ShowNotImplementedMessageBoxCommand}">
                                <MenuItem.Icon>
                                    <materialIcons:MaterialIcon Kind="ServerOutline" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{Binding Version}" IsEnabled="False">
                                <MenuItem.Icon>
                                    <materialIcons:MaterialIcon Kind="LocalOffer" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </MenuFlyout>
                    </controls:FlyoutButton.Flyout>
                    <materialIcons:MaterialIcon Kind="CogOutline" />
                </controls:FlyoutButton>
                <!-- Help -->

                <controls:FlyoutButton Margin="10 5" Classes="Clickable"
                                       Padding="7" HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch" CornerRadius="5">
                    <ToolTip.Tip>
                        <Label Content="{x:Static openSshGui:StringsAndTexts.MainWindowRightClickHelp}" />
                    </ToolTip.Tip>
                    <controls:FlyoutButton.Flyout>
                        <MenuFlyout PlacementAnchor="Top" Placement="Top">
                            <MenuItem Header="{x:Static openSshGui:StringsAndTexts.MainWindowHelpMenuWebsite}"
                                      Command="{Binding OpenBrowserCommand}">
                                <MenuItem.CommandParameter>
                                    <sys:Int32>0</sys:Int32>
                                </MenuItem.CommandParameter>
                                <MenuItem.Icon>
                                    <materialIcons:MaterialIcon Kind="Web" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="{x:Static openSshGui:StringsAndTexts.MainWindowHelpMenuQuestion}"
                                      Command="{Binding OpenBrowserCommand}">
                                <MenuItem.CommandParameter>
                                    <sys:Int32>1</sys:Int32>
                                </MenuItem.CommandParameter>
                                <MenuItem.Icon>
                                    <materialIcons:MaterialIcon Kind="LightbulbQuestionOutline" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{x:Static openSshGui:StringsAndTexts.MainWindowHelpMenuAbout}"
                                      Command="{Binding OpenBrowserCommand}">
                                <MenuItem.CommandParameter>
                                    <sys:Int32>2</sys:Int32>
                                </MenuItem.CommandParameter>
                                <MenuItem.Icon>
                                    <materialIcons:MaterialIcon Kind="Help" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </MenuFlyout>
                    </controls:FlyoutButton.Flyout>
                    <materialIcons:MaterialIcon Kind="HelpCircleOutline" />
                </controls:FlyoutButton>
            </UniformGrid>
        </Border>
    </Grid>
</Window>