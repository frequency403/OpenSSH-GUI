<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
                    xmlns:openSshGui="clr-namespace:OpenSSH_GUI.Resources"
                    xmlns:viewModels="clr-namespace:OpenSSH_GUI.ViewModels"
                    xmlns:converters="clr-namespace:OpenSSH_GUI.Converters"
                    xmlns:keys="clr-namespace:OpenSSH_GUI.Core.Lib.Keys;assembly=OpenSSH_GUI.Core">
    <!-- ReSharper disable once Xaml.StaticResourceNotResolved -->
    <ControlTheme x:Key="SshKeyItemContainerTheme" BasedOn="{StaticResource {x:Type ComboBoxItem}}"
                  TargetType="{x:Type ComboBoxItem}">
        <ControlTheme.Setters>
            <Setter Property="IsEnabled" Value="{Binding IsInitialized, DataType=keys:SshKeyFile}" />
        </ControlTheme.Setters>
    </ControlTheme>
    <DataTemplate x:Key="SshKeyComboBoxStyle" DataType="keys:SshKeyFile">
        <StackPanel Orientation="Horizontal" Spacing="15">
            <StackPanel HorizontalAlignment="Left" Spacing="10" Margin="0" Orientation="Horizontal">
                <Panel IsVisible="{Binding !Password.IsValid}">
                    <avalonia:MaterialIcon Kind="EncryptionOffOutline" Foreground="{DynamicResource DisconnectedBrush}"
                                           IsVisible="{Binding !NeedsPassword}" />
                    <avalonia:MaterialIcon Kind="EncryptionOutline" Foreground="{DynamicResource CodeForegroundBrush}"
                                           IsVisible="{Binding NeedsPassword}" />
                </Panel>
                <avalonia:MaterialIcon IsVisible="{Binding Password.IsValid}" Kind="EncryptionCheck"
                                       Foreground="{DynamicResource ConnectedBrush}" />
                <avalonia:MaterialIcon IsVisible="{Binding IsPuttyKey}" Kind="KeyChain"
                                       Foreground="{DynamicResource ConnectingBrush}" />
                <avalonia:MaterialIcon IsVisible="{Binding !IsPuttyKey}" Kind="FileKeyOutline"
                                       Foreground="{DynamicResource VerifiedBrush}" />
            </StackPanel>
            <StackPanel HorizontalAlignment="Left">
                <StackPanel.Styles>
                    <Style Selector="TextBlock.MiniText">
                        <Setter Property="FontStyle" Value="Normal" />
                        <Setter Property="FontWeight" Value="Light" />
                        <Setter Property="FontSize" Value="10" />
                    </Style>
                </StackPanel.Styles>
                <TextBlock HorizontalAlignment="Left" Margin="0" Classes="MiniText"
                           Text="{Binding Format, Converter={x:Static converters:Converter.FormatToStringConverter}}" />
                <Separator Margin="0" />
                <TextBlock HorizontalAlignment="Left" Margin="0" Classes="MiniText" Text="{Binding FileName}" />
            </StackPanel>
        </StackPanel>
    </DataTemplate>
    <DataTemplate x:Key="SshKeyExportButtons" DataType="keys:SshKeyFile">
        <UniformGrid Rows="1" Columns="0" ColumnSpacing="10" HorizontalAlignment="Center">
                        <Button Padding="5" Background="{DynamicResource RevokedBrush}"
                                HorizontalAlignment="Stretch" IsEnabled="{Binding !NeedsPassword}"
                                Command="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).ShowPublicKeyExportWindowCommand}"
                                CommandParameter="{Binding .}">
                            <ToolTip.Tip>
                                <Label
                                    Content="{x:Static openSshGui:StringsAndTexts.MainWindowDataGridControlsExportPublicKeyToolTipText}" />
                            </ToolTip.Tip>
                            <StackPanel Orientation="Horizontal">
                                <avalonia:MaterialIcon Kind="Publish" />
                                <avalonia:MaterialIcon Kind="KeyOutline" />
                            </StackPanel>
                        </Button>
                        <Button Padding="5" Background="{DynamicResource ExpiredBrush}"
                                HorizontalAlignment="Stretch"  IsEnabled="{Binding !NeedsPassword}"
                                Command="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).ShowPrivateKeyExportWindowCommand}"
                                CommandParameter="{Binding .}">
                            <ToolTip.Tip>
                                <Label
                                    Content="{x:Static openSshGui:StringsAndTexts.MainWindowDataGridControlsExportPrivateKeyToolTipText}" />
                            </ToolTip.Tip>
                            <StackPanel Orientation="Horizontal">
                                <avalonia:MaterialIcon Kind="Publish" />
                                <avalonia:MaterialIcon Kind="ShieldKeyOutline" />
                            </StackPanel>
                        </Button>
                        <Button Padding="5" Background="{DynamicResource NavigationActiveBrush}"
                                HorizontalAlignment="Stretch"
                                Command="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).OpenFileInfoWindowCommand}"
                                CommandParameter="{Binding KeyFileInfo.KeyFileSource}">
                            <ToolTip.Tip>
                                <Label
                                    Content="{x:Static openSshGui:StringsAndTexts.MainWindowOpenFileInfoWindow}" />
                            </ToolTip.Tip>
                            <StackPanel>
                                <avalonia:MaterialIcon Kind="Settings" />
                            </StackPanel>
                        </Button>
                    </UniformGrid>
    </DataTemplate>
    <DataTemplate x:Key="SshKeyFingerprintStyle" DataType="keys:SshKeyFile">
        <Panel VerticalAlignment="Center" IsEnabled="{Binding !Changing}">
            <TextBlock Padding="5" Text="{Binding Fingerprint}" Margin="5"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       IsVisible="{Binding !NeedsPassword}" />
            <Button Padding="5" HorizontalAlignment="Stretch"
                    Background="{DynamicResource AccentHoverBrush}"
                    Foreground="{DynamicResource AccentForegroundBrush}"
                    HorizontalContentAlignment="Center"
                    IsVisible="{Binding NeedsPassword}"
                    Command="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).ProvidePasswordCommand}"
                    CommandParameter="{Binding .}"
                    Content="{x:Static openSshGui:StringsAndTexts.MainWindowProvidePassword}" />
        </Panel>
    </DataTemplate>
    <DataTemplate x:Key="SshKeyTypeStyle" DataType="keys:SshKeyFile">
        <Grid ColumnDefinitions="* 3*" VerticalAlignment="Center"
                          HorizontalAlignment="Stretch">
                        <Border Grid.Column="0" HorizontalAlignment="Left" Padding="5" BorderThickness="1"
                                BorderBrush="Transparent" CornerRadius="25" Classes="WithContextMenu">
                            <Border.Styles>
                                <Style Selector="Border.WithContextMenu:pointerover">
                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                </Style>
                            </Border.Styles>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" IsVisible="{Binding Password.IsValid}">
                                    <Button Background="{DynamicResource NavigationActiveBrush}"
                                            Command="{Binding Path=$parent[Window].((viewModels:MainWindowViewModel)DataContext).ResetKeyCommand}"
                                            CommandParameter="{Binding .}">
                                        <ToolTip.Tip>
                                            <Label Content="{x:Static openSshGui:StringsAndTexts.KeysForgetPassword}" />
                                        </ToolTip.Tip>
                                        <avalonia:MaterialIcon Kind="LockReset" />
                                    </Button>
                                </StackPanel>
                                <StackPanel IsVisible="{Binding !Password.IsValid}">
                                    <avalonia:MaterialIcon Kind="EncryptionOffOutline"
                                                           Foreground="{DynamicResource DisconnectedBrush}"
                                                           IsVisible="{Binding !NeedsPassword}" />
                                    <avalonia:MaterialIcon Kind="EncryptionOutline"
                                                           Foreground="{DynamicResource CodeForegroundBrush}"
                                                           IsVisible="{Binding NeedsPassword}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2" HorizontalAlignment="Left">
                            <Border Padding="5" BorderBrush="Transparent" IsVisible="{Binding IsPuttyKey}">
                                <avalonia:MaterialIcon Kind="KeyChain" Foreground="{DynamicResource AccentHoverBrush}" />
                            </Border>
                            <Border Padding="5" BorderBrush="Transparent" IsVisible="{Binding !IsPuttyKey}">
                                <avalonia:MaterialIcon Kind="FileKeyOutline"
                                                       Foreground="{DynamicResource VerifiedBrush}" />
                            </Border>
                            <TextBlock Padding="5" Text="{Binding KeyType}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
    </DataTemplate>
</ResourceDictionary>