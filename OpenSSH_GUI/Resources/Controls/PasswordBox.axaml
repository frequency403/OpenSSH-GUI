<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="OpenSSH_GUI.Resources.Controls.PasswordBox">

    <Grid ColumnDefinitions="*, Auto">

        <TextBox x:Name="PART_TextBox"
                 Grid.Column="0"
                 PasswordChar="●"
                 Watermark="Passwort" />

        <ToggleButton x:Name="PART_Toggle"
                      Grid.Column="1"
                      Width="36"
                      Background="Transparent"
                      BorderThickness="0"
                      VerticalAlignment="Stretch"
                      Cursor="Hand">
            <Panel>
                <!-- Eye Open -->
                <avalonia:MaterialIcon x:Name="PART_EyeOpen" Kind="Eye" Width="20" Height="20" IsVisible="False" />
                
                <!-- Eye Closed -->
                <avalonia:MaterialIcon x:Name="PART_EyeClosed" Kind="EyeOff" Width="20" Height="20" IsVisible="True" />
            </Panel>
        </ToggleButton>

    </Grid>
</UserControl>