<!-- ReSharper disable InconsistentNaming -->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:controls="clr-namespace:OpenSSH_GUI.Resources.Controls"
             x:Class="OpenSSH_GUI.Resources.Controls.PasswordDisplay">
    <TextBox Name="PART_Password" LetterSpacing="2"
             RevealPassword="{Binding PasswordVisible, RelativeSource={RelativeSource AncestorType=controls:PasswordDisplay}, Mode=TwoWay}"
             PasswordChar="{Binding MaskCharacter, RelativeSource={RelativeSource AncestorType=controls:PasswordDisplay}}"
             Watermark="{Binding Watermark, RelativeSource={RelativeSource AncestorType=controls:PasswordDisplay}}"
             IsUndoEnabled="False"
             IsReadOnly="True"
             AcceptsReturn="False"
             AcceptsTab="False"
             Focusable="False"
             MaxLines="1"
             SelectionBrush="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <TextBox.InnerRightContent>
            <ToggleButton Name="PART_Toggle"
                          IsChecked="{Binding PasswordVisible, RelativeSource={RelativeSource AncestorType=controls:PasswordDisplay}, Mode=TwoWay}"
                          IsThreeState="False" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                <StackPanel>
                    <avalonia:MaterialIcon HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Kind="EyeOutline"
                                           IsVisible="{Binding PasswordVisible, RelativeSource={RelativeSource AncestorType=controls:PasswordDisplay}}" />
                    <avalonia:MaterialIcon HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Kind="EyeOffOutline"
                                           IsVisible="{Binding !PasswordVisible, RelativeSource={RelativeSource AncestorType=controls:PasswordDisplay}}" />
                </StackPanel>
            </ToggleButton>
        </TextBox.InnerRightContent>
    </TextBox>
</UserControl>